{
  "/api/": {
    "target": "http://localhost:3000",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/api/": "/" },
    "logLevel": "debug"
  },
  "/api2/": {
    "target": "http://localhost:3001",
    "secure": false,
    "changeOrigin": true,
    "pathRewrite": { "^/api2/": "/" },
    "cookieDomainRewrite": "localhost",
    "onProxyReq": "function(proxyReq, req) { if (req.headers.cookie) { proxyReq.setHeader('Cookie', req.headers.cookie); } }",
    "logLevel": "debug"
  }
}
